{
  "name": "round",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:mobile",
    "dev:api": "npm --workspace server run dev",
    "dev:mobile": "npm --workspace client run start",
    "lint": "npm-run-all --parallel lint:*",
    "lint:api": "npm --workspace server run lint",
    "lint:mobile": "npm --workspace client run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
